{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gymos.app/schemas/exercise.schema.json",
  "title": "Exercise",
  "description": "A structured exercise definition in the GymOS knowledge base",
  "type": "object",
  "required": [
    "id", "name", "category", "primary_muscles",
    "movement_pattern", "equipment", "difficulty"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z]+(_[a-z0-9]+)+$",
      "description": "Stable unique identifier, e.g. 'chest_bench_press'"
    },
    "name": {
      "type": "string",
      "description": "Display name, e.g. 'Barbell Bench Press'"
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Common alternative names for alias resolution"
    },
    "category": {
      "type": "string",
      "enum": [
        "chest", "back", "shoulders", "quads", "hamstrings_glutes",
        "biceps", "triceps", "core", "full_body", "calves",
        "forearms", "cardio", "warmup_mobility"
      ]
    },
    "primary_muscles": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Primary target muscles (must reference a valid muscle id)"
    },
    "secondary_muscles": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Synergist / stabilizer muscles"
    },
    "equipment": {
      "type": "string",
      "description": "Required equipment, e.g. 'barbell', 'dumbbell', 'cable', 'machine', 'bodyweight'"
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"]
    },
    "movement_pattern": {
      "type": "string",
      "description": "Fundamental movement pattern, e.g. 'horizontal_push', 'vertical_pull', 'hip_hinge', 'squat'"
    },
    "mechanics": {
      "type": "string",
      "enum": ["compound", "isolation", "isometric", "mobility"]
    },
    "hypertrophy_rep_range": {
      "type": "object",
      "properties": {
        "min": { "type": "integer" },
        "max": { "type": "integer" }
      },
      "description": "Optimal rep range for hypertrophy"
    },
    "rest_time": {
      "type": "object",
      "properties": {
        "min_seconds": { "type": "integer" },
        "max_seconds": { "type": "integer" },
        "label": { "type": "string" }
      },
      "description": "Recommended rest between sets"
    },
    "tempo": {
      "type": "string",
      "description": "Tempo notation, e.g. '2-1-1' (eccentric-pause-concentric)"
    },
    "range_of_motion": {
      "type": "string",
      "description": "Description of full range of motion"
    },
    "setup": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Step-by-step setup instructions"
    },
    "execution": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Step-by-step execution instructions"
    },
    "cues": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Coach cues for form correction"
    },
    "breathing": {
      "type": "string",
      "description": "Breathing pattern guidance, e.g. 'Exhale on concentric, inhale on eccentric'"
    },
    "common_mistakes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Frequent form errors to avoid"
    },
    "alternatives": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Alternative exercise IDs that target similar muscles"
    },
    "variations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Variation exercise IDs"
    },
    "progression": {
      "type": "string",
      "description": "Progression path, e.g. 'Negative → Band Assisted → Strict → Weighted'"
    },
    "spotting": {
      "type": "string",
      "description": "Spotting instructions"
    },
    "rep_ranges": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Rep ranges by goal, e.g. {'hypertrophy': '8-15', 'strength': '5-8'}"
    },
    "advantages": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Key advantages of this exercise"
    },
    "weight_progression": {
      "type": "string",
      "description": "Recommended weight progression scheme"
    },
    "alterations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Alterations or modifications"
    },
    "recommendation": {
      "type": "string",
      "description": "General training recommendation"
    },
    "alternative": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ],
      "description": "Alternative exercise reference(s)"
    },
    "uses": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ],
      "description": "Common uses for this exercise"
    },
    "shoulder_safety_note": {
      "type": "string",
      "description": "Shoulder safety considerations"
    },
    "triceps_activation": {
      "type": "string",
      "description": "Triceps activation notes"
    },
    "purpose": {
      "type": "string",
      "description": "Purpose of this warmup/mobility exercise"
    },

    "movement_plane": {
      "type": "string",
      "enum": ["sagittal", "frontal", "transverse", "multi_planar", "none"],
      "description": "Primary plane of movement"
    },
    "stability_requirement": {
      "type": "string",
      "enum": ["low", "moderate", "high"],
      "description": "Core / stabilizer demand level"
    },
    "skill_requirement": {
      "type": "string",
      "enum": ["low", "moderate", "high"],
      "description": "Technical skill / coordination required"
    },
    "fatigue_score": {
      "type": "number",
      "minimum": 1,
      "maximum": 10,
      "description": "Subjective fatigue cost (1=minimal, 10=exhausting)"
    },
    "systemic_fatigue": {
      "type": "string",
      "enum": ["low", "moderate", "high"],
      "description": "Systemic / CNS fatigue impact"
    },
    "joint_stress": {
      "type": "object",
      "properties": {
        "overall": { "type": "string", "enum": ["low", "moderate", "high"] },
        "notes": { "type": "string" }
      },
      "description": "Joint stress assessment"
    },
    "force_curve": {
      "type": "string",
      "enum": ["ascending", "descending", "peaked", "flat", "variable"],
      "description": "Strength curve profile"
    },
    "resistance_profile": {
      "type": "string",
      "enum": ["constant", "linear_variable", "exponential", "accommodating", "ascending", "descending"],
      "description": "How resistance changes through range of motion"
    },
    "unilateral_bilateral": {
      "type": "string",
      "enum": ["unilateral", "bilateral", "both"],
      "description": "Whether exercise is performed one or two limbs at a time"
    },
    "recommended_rir": {
      "type": "object",
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 },
        "description": { "type": "string" }
      },
      "description": "Recommended Reps in Reserve range"
    },
    "muscle_contributions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["muscle_id", "percentage"],
        "properties": {
          "muscle_id": { "type": "string" },
          "percentage": { "type": "number", "minimum": 0, "maximum": 100 }
        }
      },
      "description": "Contribution percentages for effective volume calculation"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Arbitrary tags for exercise categorization and searching"
    },
    "knowledge_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of this knowledge entry"
    },
    "last_updated": {
      "type": "string",
      "format": "date",
      "description": "Date this entry was last updated (YYYY-MM-DD)"
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "authors": {
            "type": "array",
            "items": { "type": "string" }
          },
          "year": { "type": "integer" },
          "type": {
            "type": "string",
            "enum": ["study", "article", "book", "expert_opinion", "other"]
          }
        }
      },
      "description": "Scientific / expert references supporting this entry"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "knowledge_version": { "type": "string" } },
        "required": ["knowledge_version"]
      },
      "then": {
        "required": ["last_updated"]
      }
    }
  ]
}
