{
  "id": "chest_cable_crossover",
  "name": "Cable Crossover",
  "category": "chest",
  "primary_muscles": ["pectoralis_major"],
  "secondary_muscles": ["anterior_deltoid"],
  "equipment": "cable",
  "difficulty": "beginner",
  "movement_pattern": "horizontal_adduction",
  "mechanics": "isolation",
  "setup": [
    "Set pulleys to highest position",
    "Stand in center, staggered stance",
    "Grab handles with palms facing forward/down"
  ],
  "execution": [
    "Lean forward slightly, hands start wide",
    "Pull hands down and together in front of chest",
    "Cross hands past each other for full contraction",
    "Control back to starting position"
  ],
  "tempo": "2-1-3",
  "common_mistakes": [
    "Using momentum instead of chest",
    "Not crossing past midline",
    "Arms too straight (shoulder stress)"
  ],
  "cues": [
    "Squeeze chest at crossover point",
    "Think 'big chest at start, forced air out at finish'",
    "Keep slight bend in elbows"
  ],
  "variations": [
    "low_to_high_cable_fly",
    "high_to_low_cable_fly"
  ]
}
